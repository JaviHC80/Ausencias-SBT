rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Context-Aware Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Pillar 2: Validation Blueprints
    function isValidAbsence(data) {
      return data.userId is string && data.userId.size() <= 100 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.startDate is timestamp &&
             data.endDate is timestamp &&
             data.type in ['completa', 'parcial'] &&
             data.reason in ['Vacaciones', 'Asuntos propios', 'Médico', 'Baja', 'Permiso'] &&
             data.createdAt is timestamp &&
             data.keys().hasAll(['userId', 'userName', 'startDate', 'endDate', 'type', 'reason', 'createdAt']) &&
             data.keys().size() == 7;
    }

    match /absences/{absenceId} {
      // Allow public read for calendar visibility
      allow get, list: if true;

      // Allow creation with validation
      allow create: if isValidAbsence(incoming());

      // Allow updates/deletes with validation
      // Note: Real security would require enabling an Auth provider in Firebase console.
      allow update: if isValidAbsence(incoming());
      allow delete: if true;
    }
  }
}
